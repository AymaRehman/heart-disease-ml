import pandas as pd
import matplotlib.pyplot as plt
from ucimlrepo import fetch_ucirepo
# Fetch the Heart Disease dataset from UCI Machine Learning Repository
heart_disease = fetch_ucirepo(id=45)
# Get features (X) and targets (y) as pandas DataFrames
X = heart_disease.data.features
y = heart_disease.data.targets
# Combine features and target into a single DataFrame
df = pd.concat([X, y], axis=1)
# Rename the target column to 'target' if it's not already named that
# The original UCI dataset often names this column 'num' or similar
# Let's assume the target column is the last column in 'y' and rename it.
if 'num' in df.columns:
    df = df.rename(columns={'num': 'target'})
elif 'target' not in df.columns and len(y.columns) == 1:
    df = df.rename(columns={y.columns[0]: 'target'})
# Convert target to integer if it's float or object
df['target'] = df['target'].astype(int)
# Handle missing values if any, for example, by dropping rows with NaNs
df = df.dropna()

plt.figure()
for label in df["target"].unique():
    subset = df[df["target"] == label]
    plt.hist(subset["thalach"], bins=15, alpha=0.5, label=f"Class {label}")

plt.xlabel("Thalach")
plt.ylabel("Frequency")
plt.title("Histogram: Thalach by Class")
plt.legend()
plt.show()

plt.figure()
for label in df["target"].unique():
    subset = df[df["target"] == label]
    plt.hist(subset["oldpeak"], bins=15, alpha=0.5, label=f"Class {label}")

plt.xlabel("Oldpeak")
plt.ylabel("Frequency")
plt.title("Histogram: Oldpeak by Class")
plt.legend()
plt.show()

plt.figure()
df.boxplot(column="thalach", by="target")
plt.title("Box Plot: Thalach vs Target")
plt.suptitle("")
plt.xlabel("Target (0 = No Disease, 1 = Disease)")
plt.ylabel("Thalach")
plt.show()

import seaborn as sns
plt.figure()
sns.violinplot(x="target", y="oldpeak", data=df)
plt.title("Violin Plot: Oldpeak vs Target")
plt.show()

stats = df.describe().T
# Add extra indicators
stats["median"] = df.median()
stats["variance"] = df.var()
print("Statistical Summary:")
print(stats)
